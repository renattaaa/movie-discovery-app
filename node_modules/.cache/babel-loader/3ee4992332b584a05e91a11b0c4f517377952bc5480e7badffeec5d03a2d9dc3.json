{"ast":null,"code":"import axios from \"axios\";\nexport default {\n  data() {\n    return {\n      movies: []\n    };\n  },\n  created() {\n    axios.get(\"https://api.themoviedb.org/3/trending/all/day\", {\n      params: {\n        api_key: \"89e5ec645c9342a4719cc7f1aa1bd004\"\n      }\n    }).then(response => {\n      this.movies = response.data.results;\n    }).catch(error => {\n      console.error(\"Terjadi kesalahan:\", error);\n    });\n  }\n};","map":{"version":3,"names":["axios","data","movies","created","get","params","api_key","then","response","results","catch","error","console"],"sources":["src/components/home/RecentList.vue"],"sourcesContent":["<template>\r\n  <div :disabled=\"true\" class=\"RecentList\">\r\n    <v-list-item v-for=\"movie in movies\" :key=\"movie.id\" class=\"pa-2\">\r\n      <v-img\r\n        :src=\"'https://image.tmdb.org/t/p/original' + movie.poster_path\"\r\n        :alt=\"movie.title\"\r\n        width=\"87\"\r\n        height=\"130\"\r\n        class=\"card-image ml-2\"\r\n      ></v-img>\r\n      <v-list-item-title class=\"ml-2\"\r\n        >{{ movie.title }}\r\n        <v-list-item-subtitle class=\"mt-2\">{{\r\n          movie.release_date\r\n        }}</v-list-item-subtitle>\r\n      </v-list-item-title>\r\n    </v-list-item>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport axios from \"axios\";\r\n\r\nexport default {\r\n  data() {\r\n    return {\r\n      movies: [],\r\n    };\r\n  },\r\n  created() {\r\n    axios\r\n      .get(\"https://api.themoviedb.org/3/trending/all/day\", {\r\n        params: {\r\n          api_key: \"89e5ec645c9342a4719cc7f1aa1bd004\",\r\n        },\r\n      })\r\n      .then((response) => {\r\n        this.movies = response.data.results;\r\n      })\r\n      .catch((error) => {\r\n        console.error(\"Terjadi kesalahan:\", error);\r\n      });\r\n  },\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n.RecentList {\r\n  height: 400px;\r\n  overflow: auto;\r\n  background: linear-gradient(to bottom, #0a0a0aca, #08080800);\r\n  scrollbar-width: thin;\r\n  scrollbar-color: #555555 #0a0a0a;\r\n}\r\n\r\n.RecentList::-webkit-scrollbar {\r\n  width: 8px;\r\n}\r\n\r\n.RecentList::-webkit-scrollbar-thumb {\r\n  background-color: #555555;\r\n  border-radius: 4px;\r\n}\r\n\r\n.RecentList::-webkit-scrollbar-thumb:hover {\r\n  background-color: #333;\r\n}\r\n\r\n.RecentList {\r\n  scrollbar-width: thin; \r\n  scrollbar-color: #555555 #0a0a0a; \r\n}\r\n\r\n.RecentList:hover {\r\n  scrollbar-color: #333 #0a0a0a; \r\n}\r\n\r\n.v-list {\r\n  box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);\r\n  transition: transform 0.2s;\r\n}\r\n.v-list:hover {\r\n  transform: translateX(-4px);\r\n}\r\n\r\n.card-image {\r\n  width: 100%;\r\n  height: 100%;\r\n}\r\n</style>\r\n"],"mappings":"AAqBA,OAAAA,KAAA;AAEA;EACAC,KAAA;IACA;MACAC,MAAA;IACA;EACA;EACAC,QAAA;IACAH,KAAA,CACAI,GAAA;MACAC,MAAA;QACAC,OAAA;MACA;IACA,GACAC,IAAA,CAAAC,QAAA;MACA,KAAAN,MAAA,GAAAM,QAAA,CAAAP,IAAA,CAAAQ,OAAA;IACA,GACAC,KAAA,CAAAC,KAAA;MACAC,OAAA,CAAAD,KAAA,uBAAAA,KAAA;IACA;EACA;AACA"},"metadata":{},"sourceType":"module","externalDependencies":[]}