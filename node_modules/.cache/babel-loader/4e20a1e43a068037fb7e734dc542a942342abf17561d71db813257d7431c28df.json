{"ast":null,"code":"import axios from \"axios\";\nexport default {\n  data() {\n    return {\n      activeIndex: 0,\n      movies: []\n    };\n  },\n  created() {\n    axios.get(\"https://api.themoviedb.org/3/trending/all/day\", {\n      params: {\n        api_key: \"89e5ec645c9342a4719cc7f1aa1bd004\"\n      }\n    }).then(response => {\n      this.movies = response.data.results;\n    }).catch(error => {\n      console.error(\"Terjadi kesalahan:\", error);\n    });\n  },\n  methods: {\n    showFullOverview(movie) {\n      alert(movie.overview);\n    }\n  }\n};","map":{"version":3,"names":["axios","data","activeIndex","movies","created","get","params","api_key","then","response","results","catch","error","console","methods","showFullOverview","movie","alert","overview"],"sources":["src/components/home/CardSlider.vue"],"sourcesContent":["<template>\r\n  <v-container class=\"mt-4\">\r\n    <v-carousel\r\n      v-model=\"activeIndex\"\r\n      cycle\r\n      hide-delimiter-background\r\n      hide-delimiters\r\n    >\r\n      <v-carousel-item v-for=\"movie in movies\" :key=\"movie.id\">\r\n        <v-img\r\n          :src=\"'https://image.tmdb.org/t/p/original' + movie.backdrop_path\"\r\n          class=\"card-image\"\r\n        >\r\n          <div class=\"blur\"></div>\r\n          <v-row>\r\n            <v-col md=\"2\" class=\"card-content1\">\r\n              <v-img\r\n                :src=\"'https://image.tmdb.org/t/p/original' + movie.poster_path\"\r\n                :alt=\"movie.title\"\r\n                width=\"87\"\r\n                height=\"130\"\r\n                class=\"card-image ml-2\"\r\n              >\r\n              </v-img>\r\n            </v-col>\r\n            <v-col class=\"card-content2\">\r\n              <v-card-title>\r\n                <div v-if=\"movie.title\">\r\n                  {{\r\n                    movie.title.length > 35\r\n                      ? movie.title.slice(0, 35) + \"...\"\r\n                      : movie.title\r\n                  }}\r\n                </div></v-card-title\r\n              >\r\n              <v-card-subtitle>\r\n                <div v-if=\"movie.overview.length > 100\">\r\n                  {{ movie.overview.slice(0, 100) }}...\r\n                  <span class=\"read-more\" @click=\"showFullOverview(movie)\"\r\n                    >Read More</span\r\n                  >\r\n                </div>\r\n                <div v-else>\r\n                  {{ movie.overview }}\r\n                </div>\r\n              </v-card-subtitle>\r\n              <v-btn text>Watch Trailer</v-btn>\r\n              <v-btn text>More Info</v-btn>\r\n            </v-col>\r\n          </v-row>\r\n        </v-img>\r\n      </v-carousel-item>\r\n    </v-carousel>\r\n  </v-container>\r\n</template>\r\n\r\n<script>\r\nimport axios from \"axios\";\r\n\r\nexport default {\r\n  data() {\r\n    return {\r\n      activeIndex: 0,\r\n      movies: [],\r\n    };\r\n  },\r\n  created() {\r\n    axios\r\n      .get(\"https://api.themoviedb.org/3/trending/all/day\", {\r\n        params: {\r\n          api_key: \"89e5ec645c9342a4719cc7f1aa1bd004\",\r\n        },\r\n      })\r\n      .then((response) => {\r\n        this.movies = response.data.results;\r\n      })\r\n      .catch((error) => {\r\n        console.error(\"Terjadi kesalahan:\", error);\r\n      });\r\n  },\r\n  methods: {\r\n    showFullOverview(movie) {\r\n      alert(movie.overview);\r\n    },\r\n  },\r\n};\r\n</script>\r\n\r\n<style>\r\n.blur {\r\n  position: absolute;\r\n  top: 0;\r\n  left: 0;\r\n  width: 100%;\r\n  height: 100%;\r\n  backdrop-filter: blur(0.4px);\r\n  background-color: rgba(0, 0, 0, 0.235);\r\n  z-index: -1;\r\n}\r\n\r\n.card-content1 {\r\n  margin-top: 50%;\r\n  margin-left: 30px;\r\n}\r\n\r\n.card-content2 {\r\n  margin-top: 47%;\r\n  margin-left: 10px;\r\n}\r\n\r\n.v-card {\r\n  box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);\r\n  transition: transform 0.2s;\r\n}\r\n.v-card:hover {\r\n  transform: translateY(-4px);\r\n}\r\n\r\n.card-image {\r\n  width: 100%;\r\n  height: 100%;\r\n}\r\n\r\n.read-more {\r\n  color: rgb(23, 23, 255);\r\n  cursor: pointer;\r\n}\r\n</style>\r\n"],"mappings":"AAyDA,OAAAA,KAAA;AAEA;EACAC,KAAA;IACA;MACAC,WAAA;MACAC,MAAA;IACA;EACA;EACAC,QAAA;IACAJ,KAAA,CACAK,GAAA;MACAC,MAAA;QACAC,OAAA;MACA;IACA,GACAC,IAAA,CAAAC,QAAA;MACA,KAAAN,MAAA,GAAAM,QAAA,CAAAR,IAAA,CAAAS,OAAA;IACA,GACAC,KAAA,CAAAC,KAAA;MACAC,OAAA,CAAAD,KAAA,uBAAAA,KAAA;IACA;EACA;EACAE,OAAA;IACAC,iBAAAC,KAAA;MACAC,KAAA,CAAAD,KAAA,CAAAE,QAAA;IACA;EACA;AACA"},"metadata":{},"sourceType":"module","externalDependencies":[]}