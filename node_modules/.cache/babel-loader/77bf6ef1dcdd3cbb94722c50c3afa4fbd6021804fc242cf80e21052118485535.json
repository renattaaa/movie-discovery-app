{"ast":null,"code":"import axios from \"axios\";\nimport Navbar from \"@/components/header/Navbar.vue\";\nexport default {\n  name: \"PopularComponent\",\n  data() {\n    return {\n      movies: [],\n      genres: []\n    };\n  },\n  created() {\n    axios.get(\"https://api.themoviedb.org/3/movie/now_playing\", {\n      params: {\n        api_key: \"89e5ec645c9342a4719cc7f1aa1bd004\"\n      }\n    }).then(response => {\n      this.movies = response.data.results;\n    }).catch(error => {\n      console.error(\"Terjadi kesalahan:\", error);\n    });\n    axios.get(\"https://api.themoviedb.org/3/genre/movie/list\", {\n      params: {\n        api_key: \"89e5ec645c9342a4719cc7f1aa1bd004\"\n      }\n    }).then(response => {\n      this.genres = response.data.genres;\n    }).catch(error => {\n      console.error(\"Terjadi kesalahan:\", error);\n    });\n  },\n  methods: {\n    genreTypeName(genreId) {\n      const genre = this.genres.find(g => g.id === genreId);\n      return genre ? genre.name : \"\";\n    }\n  },\n  components: {\n    Navbar\n  }\n};","map":{"version":3,"names":["axios","Navbar","name","data","movies","genres","created","get","params","api_key","then","response","results","catch","error","console","methods","genreTypeName","genreId","genre","find","g","id","components"],"sources":["src/components/movie-lists/NowPlaying.vue"],"sourcesContent":["<template>\r\n  <div>\r\n    <Navbar />\r\n    <v-item-group>\r\n      <v-container>\r\n        <h2 class=\"my-10\" justify=\"center\" align=\"center\">Now Playing</h2>\r\n        <v-row>\r\n          <v-col\r\n            v-for=\"movie in movies\"\r\n            :key=\"movie.id\"\r\n            cols=\"12\"\r\n            md=\"2\"\r\n            sm=\"3\"\r\n          >\r\n            <v-hover v-slot=\"{ hover }\" open-delay=\"100\">\r\n              <v-card\r\n                :elevation=\"hover ? 16 : 2\"\r\n                :class=\"{ 'on-hover': hover }\"\r\n              >\r\n                <router-link\r\n                  :to=\"`/movies/${movie.id}`\"\r\n                  ><img\r\n                    :src=\"'https://image.tmdb.org/t/p/original' + movie.poster_path\"\r\n                    :alt=\"movie.title\"\r\n                    aspect-rasio=\"1\"\r\n                  />\r\n                </router-link>\r\n                <v-card-title>\r\n                  <div class=\"card-text\">\r\n                    {{ movie.title }}\r\n                  </div>\r\n                </v-card-title>\r\n                <v-card-text>\r\n                  <v-row align=\"center\" class=\"mx-0\">\r\n                    <v-rating\r\n                      :value=\"movie.vote_average / 2\"\r\n                      color=\"amber\"\r\n                      dense\r\n                      half-increments\r\n                      readonly\r\n                      size=\"14\"\r\n                    ></v-rating>\r\n                    <div class=\"grey--text\">\r\n                      {{ movie.vote_average * 10 }} % | {{ movie.release_date }}\r\n                    </div>\r\n                    <div class=\"my-4 card-text\">\r\n                      <span\r\n                        v-for=\"(genreId, index) in movie.genre_ids\"\r\n                        :key=\"genreId\"\r\n                      >\r\n                        {{ genreTypeName(genreId, index)\r\n                        }}<span v-if=\"index < movie.genre_ids.length - 1\"\r\n                          >,\r\n                        </span>\r\n                      </span>\r\n                    </div>\r\n                  </v-row>\r\n                </v-card-text>\r\n              </v-card>\r\n            </v-hover>\r\n          </v-col>\r\n        </v-row>\r\n      </v-container>\r\n    </v-item-group>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport axios from \"axios\";\r\nimport Navbar from \"@/components/header/Navbar.vue\";\r\n\r\nexport default {\r\n  name: \"PopularComponent\",\r\n  data() {\r\n    return {\r\n      movies: [],\r\n      genres: [],\r\n    };\r\n  },\r\n  created() {\r\n    axios\r\n      .get(\"https://api.themoviedb.org/3/movie/now_playing\", {\r\n        params: {\r\n          api_key: \"89e5ec645c9342a4719cc7f1aa1bd004\",\r\n        },\r\n      })\r\n      .then((response) => {\r\n        this.movies = response.data.results;\r\n      })\r\n      .catch((error) => {\r\n        console.error(\"Terjadi kesalahan:\", error);\r\n      });\r\n\r\n    axios\r\n      .get(\"https://api.themoviedb.org/3/genre/movie/list\", {\r\n        params: {\r\n          api_key: \"89e5ec645c9342a4719cc7f1aa1bd004\",\r\n        },\r\n      })\r\n      .then((response) => {\r\n        this.genres = response.data.genres;\r\n      })\r\n      .catch((error) => {\r\n        console.error(\"Terjadi kesalahan:\", error);\r\n      });\r\n  },\r\n  methods: {\r\n    genreTypeName(genreId) {\r\n      const genre = this.genres.find((g) => g.id === genreId);\r\n      return genre ? genre.name : \"\";\r\n    },\r\n  },\r\n\r\n  components: {\r\n    Navbar,\r\n  },\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n.card-text {\r\n  max-height: 10%;\r\n  overflow: hidden;\r\n  white-space: nowrap;\r\n  text-overflow: ellipsis;\r\n}\r\n\r\nimg {\r\n  max-width: 100%;\r\n  height: auto;\r\n}\r\n</style>\r\n"],"mappings":"AAoEA,OAAAA,KAAA;AACA,OAAAC,MAAA;AAEA;EACAC,IAAA;EACAC,KAAA;IACA;MACAC,MAAA;MACAC,MAAA;IACA;EACA;EACAC,QAAA;IACAN,KAAA,CACAO,GAAA;MACAC,MAAA;QACAC,OAAA;MACA;IACA,GACAC,IAAA,CAAAC,QAAA;MACA,KAAAP,MAAA,GAAAO,QAAA,CAAAR,IAAA,CAAAS,OAAA;IACA,GACAC,KAAA,CAAAC,KAAA;MACAC,OAAA,CAAAD,KAAA,uBAAAA,KAAA;IACA;IAEAd,KAAA,CACAO,GAAA;MACAC,MAAA;QACAC,OAAA;MACA;IACA,GACAC,IAAA,CAAAC,QAAA;MACA,KAAAN,MAAA,GAAAM,QAAA,CAAAR,IAAA,CAAAE,MAAA;IACA,GACAQ,KAAA,CAAAC,KAAA;MACAC,OAAA,CAAAD,KAAA,uBAAAA,KAAA;IACA;EACA;EACAE,OAAA;IACAC,cAAAC,OAAA;MACA,MAAAC,KAAA,QAAAd,MAAA,CAAAe,IAAA,CAAAC,CAAA,IAAAA,CAAA,CAAAC,EAAA,KAAAJ,OAAA;MACA,OAAAC,KAAA,GAAAA,KAAA,CAAAjB,IAAA;IACA;EACA;EAEAqB,UAAA;IACAtB;EACA;AACA"},"metadata":{},"sourceType":"module","externalDependencies":[]}