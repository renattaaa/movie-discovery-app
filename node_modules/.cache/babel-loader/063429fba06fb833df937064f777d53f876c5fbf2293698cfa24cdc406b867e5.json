n      try {\r\n        const response = await axios.get(\r\n          \"https://api.themoviedb.org/3/search/movie\",\r\n          {\r\n            params: {\r\n              api_key: \"89e5ec645c9342a4719cc7f1aa1bd004\",\r\n              query: this.search,\r\n            },\r\n          }\r\n        );\r\n        console.log(response.data.results);\r\n        this.movies = response.data.results;\r\n      } catch (error) {\r\n        console.error(\"Terjadi kesalahan:\", error);\r\n      }\r\n    },\r\n    searchResults() {\r\n      this.searchQuery();\r\n       this.$router.push({ name: \"search\", query: { q: this.search } });\r\n    },\r\n  },\r\n};\r\n</script>\r\n\r\n<style>\r\n.movies-search {\r\n  position: absolute;\r\n  border-radius: 15px;\r\n  color: black;\r\n  padding-left: 15px;\r\n  font-weight: 500;\r\n  width: 30%;\r\n  height: 30px;\r\n}\r\n</style>"],"mappings":";AAyBA,OAAAA,KAAA;AACA;EACAC,IAAA;EACAC,IAAA,EAAAA,CAAA;IACAC,MAAA;IACAC,MAAA;EACA;EACAC,OAAA;IACA,MAAAC,YAAA;MACA;QACA,MAAAC,QAAA,SAAAP,KAAA,CAAAQ,GAAA,CACA,6CACA;UACAC,MAAA;YACAC,OAAA;YACAC,KAAA,OAAAR;UACA;QACA,CACA;QACAS,OAAA,CAAAC,GAAA,CAAAN,QAAA,CAAAL,IAAA,CAAAY,OAAA;QACA,KAAAV,MAAA,GAAAG,QAAA,CAAAL,IAAA,CAAAY,OAAA;MACA,SAAAC,KAAA;QACAH,OAAA,CAAAG,KAAA,uBAAAA,KAAA;MACA;IACA;IACAC,cAAA;MACA,KAAAV,WAAA;MACA,KAAAW,OAAA,CAAAC,IAAA;QAAAjB,IAAA;QAAAU,KAAA;UAAAQ,CAAA,OAAAhB;QAAA;MAAA;IACA;EACA;AACA"},"metadata":{},"sourceType":"module","externalDependencies":[]}