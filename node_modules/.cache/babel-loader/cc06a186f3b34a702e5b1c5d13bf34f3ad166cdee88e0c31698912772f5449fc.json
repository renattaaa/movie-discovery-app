ration: none;\r\n}\r\n\r\n.link {\r\n  text-decoration: none;\r\n  color: inherit;\r\n}\r\n</style>\r\n"],"mappings":"AAuCA;EACAA,IAAA;EACAC,IAAA,EAAAA,CAAA;IACAC,KAAA,GACA;MAAAF,IAAA;MAAAG,IAAA;IAAA,GACA;MAAAH,IAAA;MAAAG,IAAA;IAAA,GACA;MAAAH,IAAA;MAAAG,IAAA;IAAA;EAEA;AACA"},"metadata":{},"sourceType":"module","externalDependencies":[]}